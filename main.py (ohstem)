def on_event_timer_callback_sensor():
    global RT, RH, LUX
    try:
        aiot_dht20.read_dht20()
        RT = aiot_dht20.dht20_temperature()
        RH = aiot_dht20.dht20_humidity()
        LUX = round(translate(pin2.read_analog(), 0, 4095, 0, 100))

        aiot_lcd1602.move_to(0, 0)
        aiot_lcd1602.putstr('                ')
        aiot_lcd1602.move_to(0, 0)
        aiot_lcd1602.putstr(str(RT) + '*C   ' + str(RH) + '%   ' + str(LUX))

        if LUX < 30:
            tiny_rgb.show(4, hex_to_rgb('#0000ff'))
        elif LUX < 70:
            tiny_rgb.show(4, hex_to_rgb('#ffff00'))
        else:
            tiny_rgb.show(4, hex_to_rgb('#ff0000'))

        mqtt.publish('V1', str(RT))
        mqtt.publish('V2', str(RH))
        mqtt.publish('V3', str(LUX))
    except Exception as e:
        pass

event_manager.add_timer_event(1000, on_event_timer_callback_sensor)

def on_event_timer_callback_time():
    try:
        (year, month, mday, week_of_year, hour, minute, second, milisecond) = RTC().datetime()
        time_str = '%02d/%02d/%02d    %02d:%02d' % (mday, month, year, hour, minute)
        aiot_lcd1602.move_to(0, 1)
        aiot_lcd1602.putstr(time_str)
    except Exception as e:
        pass

event_manager.add_timer_event(1000, on_event_timer_callback_time)

def tinh_mau_den(do_sang_str):
    try:
        do_sang = int(do_sang_str)
        if do_sang == 0: return hex_to_rgb('#000000')
        return hex_to_rgb('#%02x%02x%02x' % (int((do_sang/100)*255), int((do_sang/100)*200), int((do_sang/100)*100)))
    except:
        return hex_to_rgb('#000000')

def on_mqtt_message_v4(msg): tiny_rgb.show(1, tinh_mau_den(msg))
def on_mqtt_message_v5(msg): tiny_rgb.show(2, tinh_mau_den(msg))
def on_mqtt_message_v6(msg): tiny_rgb.show(3, tinh_mau_den(msg))

# ==========================================
# XỬ LÝ CỬA SERVO (ĐÃ FIX LỖI & TỐI ƯU)
# ==========================================
dang_mo_cua = False
thoi_gian_mo = 0
thoi_gian_bat_may = 0 
THOI_GIAN_MO_CUA = 7000

def on_mqtt_message_v7(msg):
    global dang_mo_cua, thoi_gian_mo, thoi_gian_bat_may
    du_lieu = str(msg).strip()
    
    # KHIÊN BẢO VỆ: Chặn mọi tin nhắn ma trong 3 giây sau khi CÓ MẠNG
    # Sử dụng ticks_diff để chống lỗi tràn bộ đếm
    if time.ticks_diff(time.ticks_ms(), thoi_gian_bat_may) < 3000:
        print("=> Da chan lenh rac:", du_lieu)
        return

    if du_lieu == '1':
        thoi_gian_mo = time.ticks_ms() # Reset lại mốc thời gian
        if dang_mo_cua == False:
            print("=> NGUOI QUEN: Mo cua!")
            pin4.servo_write(90)
            display.show(Image.YES)
            dang_mo_cua = True
        else:
            print("=> Gia han them 7 giay mo cua!")
            
    elif du_lieu == '0':
        if dang_mo_cua == True:
            print("=> KHOA CUA TỪ XA!")
            pin4.servo_write(0)
            display.show(Image.NO)
            dang_mo_cua = False

def canh_gio_dong_cua():
    global dang_mo_cua, thoi_gian_mo
    try:
        # Sử dụng time.ticks_diff thay vì dấu trừ trực tiếp
        thoi_gian_da_troi_qua = time.ticks_diff(time.ticks_ms(), thoi_gian_mo)
        
        if dang_mo_cua == True and (thoi_gian_da_troi_qua >= THOI_GIAN_MO_CUA):
            print("=> HET 7 GIAY, TU DONG DONG CUA!")
            pin4.servo_write(0)
            display.show(Image.NO)
            dang_mo_cua = False
            mqtt.publish('V7', '0') # Đồng bộ trạng thái về Dashboard
    except Exception as e:
        pass


event_manager.add_timer_event(500, canh_gio_dong_cua)

